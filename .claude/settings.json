{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(git *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(python3 *)",
      "Bash(curl *)",
      "Bash(md5 *)",
      "Bash(fc-query *)",
      "Bash(pip3 install *)",
      "Bash(gh *)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-approve.sh"
          }
        ]
      }
    ]
  }
}
